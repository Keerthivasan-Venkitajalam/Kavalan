# Environment Configuration Example
# Copy this file to .env.{ENVIRONMENT} and customize for your environment
# Supported environments: development, staging, production, test

# Environment
ENVIRONMENT=development

# Database URLs
DATABASE_URL=postgresql://kavalan_user:kavalan_dev_password@localhost:5432/kavalan
MONGODB_URL=mongodb://kavalan_user:kavalan_dev_password@localhost:27017/kavalan
REDIS_URL=redis://localhost:6379/0

# API Keys (replace with actual keys)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (IMPORTANT: Use a strong secret in production!)
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS Origins (comma-separated list)
# For development: use * to allow all origins
# For production: specify exact extension IDs and domains
CORS_ORIGINS=chrome-extension://your-extension-id,https://your-domain.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Configuration Loading Priority:
# 1. Environment variables (highest priority)
# 2. Environment-specific file (.env.{ENVIRONMENT})
# 3. Base file (.env)
# 4. Default values (lowest priority)
#
# To use environment-specific configuration:
# 1. Copy this file to .env.development, .env.staging, or .env.production
# 2. Customize values for that environment
# 3. Set ENVIRONMENT variable: export ENVIRONMENT=production
# 4. Start the application
#
# See docs/CONFIGURATION.md for detailed documentation

