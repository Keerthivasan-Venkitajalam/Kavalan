# Development environment configuration
ENVIRONMENT=development

# Database URLs (local development)
DATABASE_URL=postgresql://kavalan_user:kavalan_dev_password@localhost:5432/kavalan
MONGODB_URL=mongodb://kavalan_user:kavalan_dev_password@localhost:27017/kavalan
REDIS_URL=redis://localhost:6379/0

# API Keys (use development/test keys)
GEMINI_API_KEY=your_dev_gemini_api_key_here
OPENAI_API_KEY=your_dev_openai_api_key_here

# JWT Secret (dev only - not secure)
JWT_SECRET=dev_secret_key_change_in_production

# CORS Origins (allow all for development)
CORS_ORIGINS=*

# Rate Limiting (very permissive for development)
RATE_LIMIT_PER_MINUTE=1000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
