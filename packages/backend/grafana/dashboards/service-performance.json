{
  "dashboard": {
    "title": "Kavalan - Service Performance",
    "tags": ["kavalan", "performance", "services"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Audio Transcription Service",
        "type": "row",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 1
        },
        "collapsed": false
      },
      {
        "id": 2,
        "title": "Audio Transcription Latency (p50, p95, p99)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 1,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(kavalan_audio_transcription_duration_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(kavalan_audio_transcription_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(kavalan_audio_transcription_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["last", "mean", "max"]
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1.0, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Audio Task Success Rate",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 1,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(kavalan_celery_tasks_total{task_name=~\".*audio.*\", status=\"success\"}[5m])) / sum(rate(kavalan_celery_tasks_total{task_name=~\".*audio.*\"}[5m])) * 100",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 90, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Audio Tasks Processed",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 1,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum(rate(kavalan_celery_tasks_total{task_name=~\".*audio.*\"}[5m]))",
            "legendFormat": "Tasks/sec",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
