        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(kavalan_external_api_duration_seconds_bucket[5m])) by (api_name)",
            "legendFormat": "{{api_name}} (p95)",
            "refId": "A"
          }
        ],
        "options": {
