# Production environment configuration
ENVIRONMENT=production

# Database URLs (production)
DATABASE_URL=postgresql://kavalan_user:secure_production_password@prod-db:5432/kavalan
MONGODB_URL=mongodb://kavalan_user:secure_production_password@prod-mongo:27017/kavalan
REDIS_URL=redis://prod-redis:6379/0

# API Keys (use production keys)
GEMINI_API_KEY=your_production_gemini_api_key_here
OPENAI_API_KEY=your_production_openai_api_key_here

# JWT Secret (use strong production secret)
JWT_SECRET=your_strong_production_jwt_secret_here

# CORS Origins (production extension IDs only)
CORS_ORIGINS=chrome-extension://production-extension-id,https://kavalan.in

# Rate Limiting (stricter for production)
RATE_LIMIT_PER_MINUTE=60

# Celery
CELERY_BROKER_URL=redis://prod-redis:6379/0
CELERY_RESULT_BACKEND=redis://prod-redis:6379/0
