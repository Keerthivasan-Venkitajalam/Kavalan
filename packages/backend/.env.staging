# Staging environment configuration
ENVIRONMENT=staging

# Database URLs (staging)
DATABASE_URL=postgresql://kavalan_user:kavalan_staging_password@staging-db:5432/kavalan
MONGODB_URL=mongodb://kavalan_user:kavalan_staging_password@staging-mongo:27017/kavalan
REDIS_URL=redis://staging-redis:6379/0

# API Keys (use staging keys)
GEMINI_API_KEY=your_staging_gemini_api_key_here
OPENAI_API_KEY=your_staging_openai_api_key_here

# JWT Secret (use staging-specific secret)
JWT_SECRET=your_staging_jwt_secret_here

# CORS Origins (staging extension IDs)
CORS_ORIGINS=chrome-extension://staging-extension-id,https://staging.kavalan.in

# Rate Limiting (more permissive for testing)
RATE_LIMIT_PER_MINUTE=120

# Celery
CELERY_BROKER_URL=redis://staging-redis:6379/0
CELERY_RESULT_BACKEND=redis://staging-redis:6379/0
