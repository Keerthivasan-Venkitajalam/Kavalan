# Kavalan .gitignore

# Environment variables
.env
.env.local
.env.*.local

# API Keys and Credentials
config/vertex-ai-credentials.json
*.pem
*.key
*.crt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
ENV/
env/
.venv

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
*.cover
.cache
nosetests.xml
coverage.xml
*.log

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# Build outputs
packages/extension/dist/
packages/extension/build/
*.js.map
*.css.map

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
*.pid
*.seed
*.pid.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Database
*.db
*.sqlite
*.sqlite3
postgres-data/
mongodb-data/
redis-data/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Model files (too large for git)
*.pt
*.pth
*.onnx
*.pb
models/whisper-medium/
models/mediapipe/

# Monitoring data
prometheus-data/
grafana-data/

# Secrets
secrets/
*.secret

# Old/backup files
*_old.py
*_backup.py
*.backup

# Demo videos (too large)
demo_videos/
*.mp4
*.avi
*.mov

# Documentation builds
docs/_build/
site/

# Kiro internal files (keep specs and steering)
# .kiro/

# Keep important config examples
!.env.example
!config/example-credentials.json
