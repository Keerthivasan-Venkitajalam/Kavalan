# Kavalan Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# API Keys (REQUIRED)
# ============================================================================

# Google Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional, for Whisper cloud API)
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL (Structured Data)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kavalan
DB_USER=postgres
DB_PASSWORD=secure_password_here

# MongoDB (Unstructured Data)
MONGODB_URI=mongodb://localhost:27017/kavalan
MONGODB_DATABASE=kavalan

# Redis (Message Queue & Caching)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Application Configuration
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Celery Configuration
# ============================================================================

# Worker Configuration
CELERY_WORKERS=4
CELERY_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=100

# Queue Configuration
MAX_QUEUE_SIZE=1000
TASK_TIMEOUT=300

# ============================================================================
# Threat Detection Configuration
# ============================================================================

# Alert Thresholds
ALERT_THRESHOLD=7.0
HIGH_THREAT_THRESHOLD=7.0
CRITICAL_THREAT_THRESHOLD=8.5

# Score Weights
AUDIO_WEIGHT=0.45
VISUAL_WEIGHT=0.35
LIVENESS_WEIGHT=0.20

# ============================================================================
# AI Model Configuration
# ============================================================================

# Whisper (Audio Transcription)
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Gemini (Visual Analysis)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT=30

# MediaPipe (Liveness Detection)
MEDIAPIPE_MAX_FACES=2
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption
ENCRYPTION_KEY=your_encryption_key_here
ENCRYPTION_ALGORITHM=AES-256-GCM

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Observability Configuration
# ============================================================================

# Prometheus
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=kavalan-api

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# DPDP Compliance Configuration
# ============================================================================

# Data Retention
DATA_RETENTION_DAYS=2555  # 7 years for legal compliance
AUDIT_LOG_RETENTION_DAYS=2555

# Data Residency
DATA_REGION=IN  # India
CROSS_BORDER_TRANSFER_ALLOWED=false

# User Consent
CONSENT_REQUIRED=true
CONSENT_VERSION=1.0

# ============================================================================
# Development Configuration (Optional)
# ============================================================================

# Debug Mode
DEBUG=false
RELOAD=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Testing
TEST_DATABASE_URL=postgresql://postgres:test@localhost:5432/kavalan_test
TEST_MONGODB_URI=mongodb://localhost:27017/kavalan_test
